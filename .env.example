# OpenAI API key used for answer generation, query rewriting, and
# managed vector-store retrieval. Models are pinned in lib/clients/openai.ts.
OPENAI_API_KEY=

# OpenAI vector store containing the approved knowledge files. Runtime
# support requests require this ID and never create infrastructure.
OPENAI_VECTOR_STORE_ID=

# Minimum cosine similarity (0..1) a retrieved chunk must clear to be
# used as evidence; below this, the deterministic fallback fires
RAG_SIMILARITY_THRESHOLD=

# Hard cap on the number of chunks retrieved per question
RAG_MAX_CHUNKS=

# Per-IP request cap for /api/support and the window (ms) it resets on
RAG_RATE_LIMIT_MAX_REQUESTS=
RAG_RATE_LIMIT_WINDOW_MS=

# Base URL for the app (used for callbacks/links in dev vs prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000
