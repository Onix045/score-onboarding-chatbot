# Anthropic API key used by the chatbot
ANTHROPIC_API_KEY=

# Voyage AI API key used to embed knowledge chunks and user questions
VOYAGE_API_KEY=

# Voyage embedding model name (pinned in lib/clients/voyage.ts; the
# document_chunks.embedding column dimension must match this model)
VOYAGE_EMBEDDING_MODEL=

# Supabase project URL and service-role key (server-only, never exposed
# to the client) used for pgvector storage and retrieval
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Minimum cosine similarity (0..1) a retrieved chunk must clear to be
# used as evidence; below this, the deterministic fallback fires
RAG_SIMILARITY_THRESHOLD=

# Hard cap on the number of chunks retrieved per question
RAG_MAX_CHUNKS=

# Base URL for the app (used for callbacks/links in dev vs prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000
